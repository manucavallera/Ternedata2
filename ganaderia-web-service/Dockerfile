FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --legacy-peer-deps
COPY . .

ARG NEXT_PUBLIC_ENTORNO=produccion
ARG NEXT_PUBLIC_ENV_MS_BUSINESS_API_URL_PRODUCCION
ARG NEXT_PUBLIC_ENV_MS_SECURITY_API_URL_PRODUCCION
ARG NEXT_PUBLIC_API_URL

ENV NEXT_PUBLIC_ENTORNO=$NEXT_PUBLIC_ENTORNO
ENV NEXT_PUBLIC_ENV_MS_BUSINESS_API_URL_PRODUCCION=$NEXT_PUBLIC_ENV_MS_BUSINESS_API_URL_PRODUCCION
ENV NEXT_PUBLIC_ENV_MS_SECURITY_API_URL_PRODUCCION=$NEXT_PUBLIC_ENV_MS_SECURITY_API_URL_PRODUCCION
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build

RUN cp -r .next/static .next/standalone/.next/static
RUN cp -r public .next/standalone/public || true

EXPOSE 3002
CMD ["node", ".next/standalone/server.js"]
